source api
source bash_registers "chip_reg.h"


#
#  Enable the PA_SYNC output
#
chip_reg GPIO_CTRL         0x0FE0_07E0
chip_reg GPIO_SYNC         0xF002
chip_reg SRDWR_PA_MODE     0x0401
chip_reg SRDWR_VLIQ_PERIOD 0


#
#  Enable all LVDS lanes and enable idle-byte output on all lanes
#
value=0xFFFF
chip_reg B0_LVDSIF_CTRL $value
chip_reg B1_LVDSIF_CTRL $value
chip_reg B2_LVDSIF_CTRL $value
chip_reg B3_LVDSIF_CTRL $value
chip_reg B4_LVDSIF_CTRL $value
chip_reg B5_LVDSIF_CTRL $value
chip_reg B6_LVDSIF_CTRL $value
chip_reg B7_LVDSIF_CTRL $value

#
#  Set the band-gap for each lane (whatever that means)
#
value=4
chip_reg B0_SRDWR_BANK1M_PD $value
chip_reg B1_SRDWR_BANK1M_PD $value
chip_reg B2_SRDWR_BANK1M_PD $value
chip_reg B3_SRDWR_BANK1M_PD $value
chip_reg B4_SRDWR_BANK1M_PD $value
chip_reg B5_SRDWR_BANK1M_PD $value
chip_reg B6_SRDWR_BANK1M_PD $value
chip_reg B7_SRDWR_BANK1M_PD $value

#
#  Power up all of the LVDS lanes
#
chip_reg LVDSIF_IOCTRL 0x0005