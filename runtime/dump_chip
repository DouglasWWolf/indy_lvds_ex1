
source api
source bash_registers chip_reg.h



show()
{
    addr=$(($1))
    if [ $addr -eq 0 ]; then 
        printf "%25s = >>>>>> UNKNOWN <<<<<<<\n" $1
    else
        data=$(chip_reg $addr -dec)
        hi=$((data >> 16))
        lo=$((data & 65535))
        if [ $data -eq 0 ]; then
            printf "%25s = 0\n" $1
        else
            printf "%25s = %04X_%04X\n" $1 $hi $lo
        fi        
    fi
}



