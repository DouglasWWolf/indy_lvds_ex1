source api
source bash_registers "chip_reg.h"


read_and_test() 
{
    reg=$1
    expected=$2

    rb=$(chip_reg $reg -dec)
    if [ $rb -ne $expected ]; then
        echo "Register" $reg "expected" $expected "saw" $rb
        exit 1
    fi
}

read_back()
{
    expected=$(($1))

    read_and_test B0_LVDSIF_CTRL $expected
    read_and_test B1_LVDSIF_CTRL $expected
    read_and_test B2_LVDSIF_CTRL $expected
    read_and_test B3_LVDSIF_CTRL $expected
    read_and_test B4_LVDSIF_CTRL $expected
    read_and_test B5_LVDSIF_CTRL $expected
    read_and_test B6_LVDSIF_CTRL $expected
    read_and_test B7_LVDSIF_CTRL $expected
}

while :; do

    chip_reg B0_LVDSIF_CTRL 0xFFFF
    chip_reg B1_LVDSIF_CTRL 0xFFFF
    chip_reg B2_LVDSIF_CTRL 0xFFFF
    chip_reg B3_LVDSIF_CTRL 0xFFFF
    chip_reg B4_LVDSIF_CTRL 0xFFFF
    chip_reg B5_LVDSIF_CTRL 0xFFFF
    chip_reg B6_LVDSIF_CTRL 0xFFFF
    chip_reg B7_LVDSIF_CTRL 0xFFFF
   
    read_back 0xFFFF

    chip_reg B0_LVDSIF_CTRL 0
    chip_reg B1_LVDSIF_CTRL 0
    chip_reg B2_LVDSIF_CTRL 0
    chip_reg B3_LVDSIF_CTRL 0
    chip_reg B4_LVDSIF_CTRL 0
    chip_reg B5_LVDSIF_CTRL 0
    chip_reg B6_LVDSIF_CTRL 0
    chip_reg B7_LVDSIF_CTRL 0

    read_back 0

done

